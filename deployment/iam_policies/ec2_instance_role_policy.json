{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3ReportsBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::REPLACE_WITH_YOUR_REPORTS_BUCKET_NAME/*"
    },
    {
      "Sid": "AllowCodeDeployArtifactDownload",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::REPLACE_WITH_YOUR_PIPELINE_ARTIFACT_BUCKET_NAME/*"
    },
    {
      "Sid": "AllowCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:ap-south-1:*:log-group:/attendguard/*"
    }
  ]
}
