# ==============================
# Flask core settings
# ==============================
FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-string

# ==============================
# Database (Amazon RDS - PostgreSQL)
# ==============================
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=attendguard
DB_USER=attendguard_admin
DB_PASSWORD=change-this-password

# ==============================
# AWS
# ==============================
AWS_REGION=ap-south-1
S3_REPORTS_BUCKET=attendguard-reports-<your-unique-suffix>

# ==============================
# Geofence / Anomaly detection tuning
# ==============================
# Max allowed distance (in meters) from session's registered classroom location
GEOFENCE_RADIUS_METERS=100

# Minimum trust score (0-100) below which a record is auto-flagged for review
ANOMALY_TRUST_THRESHOLD=50

# Window (seconds) used to detect duplicate-device / duplicate-GPS submissions
ANOMALY_WINDOW_SECONDS=60

# ==============================
# Session / cookie
# ==============================
SESSION_COOKIE_SECURE=True
